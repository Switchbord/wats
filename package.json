{
  "name": "wats",
  "version": "0.3.29",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit -p tsconfig.release.json",
    "typecheck:full": "bunx tsc --noEmit -p tsconfig.full.json",
    "build:packages": "bun run scripts/build-packages.ts",
    "pack:smoke": "bun run scripts/pack-smoke.ts",
    "release:dry-run": "bun run scripts/release-dry-run.ts",
    "check-publish": "bun run typecheck && bun run build:packages && bun run pack:smoke && bun run publish:dry-run && bun run release:dry-run && bun test packages/testing/tests/wats31-release-ci-policy.test.ts packages/testing/tests/wats83-publishable-artifacts.test.ts packages/testing/tests/wats85-release-dry-run.test.ts packages/testing/tests/wats021-alpha-release.test.ts packages/testing/tests/wats030-release-contract.test.ts",
    "api:check": "bun run scripts/check-public-api-consistency.ts",
    "publish:dry-run": "bun run scripts/npm-publish-dry-run.ts",
    "examples:minimal-bot": "bun run --cwd examples/minimal-bot demo",
    "examples:groups": "bun run --cwd examples/groups demo",
    "examples:webhook-echo-bot": "bun run --cwd examples/webhook-echo-bot demo"
  },
  "devDependencies": {
    "@scalar/api-reference": "^1.55.1",
    "@types/bun": "^1.3.14",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*",
    "packages/testing/fixtures/*",
    "examples/minimal-bot",
    "examples/groups",
    "examples/webhook-echo-bot",
    "site"
  ]
}
