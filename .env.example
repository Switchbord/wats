# WATS alpha placeholder environment file.
# placeholder only — Do not commit real values.
# Copy to a local ignored file such as .env.local before filling secrets.

# Meta Graph API access token. Keep empty here; provide a real value only locally/secret manager.
WATS_ACCESS_TOKEN=

# WhatsApp Business Account and phone-number ids. Placeholder ids in config examples are not real account ids.
WATS_WABA_ID=
WATS_PHONE_NUMBER_ID=

# Webhook verification and signature settings.
WATS_VERIFY_TOKEN=
WATS_APP_SECRET=

# Service API bearer token for authenticated service routes.
WATS_SERVICE_TOKEN=

# Future WATS-48 persistence/database URL. Keep credential-bearing URLs out of committed files.
WATS_DATABASE_URL=

# Live mode is off by default. Future live commands must require explicit operator acknowledgement too.
WATS_LIVE_ENABLE=0
WATS_YES_LIVE=0

# Optional CLI presentation flags. Disabled by default and safe to omit/remove in forks.
WATS_CLI_ORBIT=0
WATS_CLI_STATUS_UI=0
