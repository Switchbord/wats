{
  "name": "@wats/persistence",
  "description": "Experimental persistence contracts + SQLite and Postgres adapters.",
  "version": "0.4.0-beta.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Switchbord/wats.git",
    "directory": "packages/persistence"
  },
  "homepage": "https://wats.sh",
  "bugs": {
    "url": "https://github.com/Switchbord/wats/issues"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-cloud-api",
    "sqlite",
    "persistence",
    "wats"
  ],
  "peerDependencies": {
    "pg": "^8.11.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "dependencies": {
    "@wats/internal-utils": "^0.4.0-beta.0"
  }
}
