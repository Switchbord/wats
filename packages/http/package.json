{
  "name": "@switchbord/http",
  "version": "0.3.1",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webhookServer": {
      "types": "./dist/webhookServer.d.ts",
      "import": "./dist/webhookServer.js"
    },
    "./signature": {
      "types": "./dist/signature.d.ts",
      "import": "./dist/signature.js"
    },
    "./webhookAdapter": {
      "types": "./dist/adapters/webhookAdapter.d.ts",
      "import": "./dist/adapters/webhookAdapter.js"
    },
    "./adapters/fetch": {
      "types": "./dist/adapters/fetchAdapter.d.ts",
      "import": "./dist/adapters/fetchAdapter.js"
    },
    "./adapters/bun": {
      "types": "./dist/adapters/bunAdapter.d.ts",
      "import": "./dist/adapters/bunAdapter.js"
    },
    "./adapters/node": {
      "types": "./dist/adapters/nodeAdapter.d.ts",
      "import": "./dist/adapters/nodeAdapter.js"
    }
