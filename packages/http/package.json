  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/switchbord/wats.git",
    "directory": "packages/http"
  },
  "homepage": "https://github.com/switchbord/wats#readme",
  "bugs": {
    "url": "https://github.com/switchbord/wats/issues"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-cloud-api",
    "bun",
    "typescript",
    "wats"
  ],
  "dependencies": {
    "@switchbord/crypto": "^0.3.1",
    "@switchbord/core": "^0.3.1",
    "@switchbord/types": "^0.3.1"
  }
}
