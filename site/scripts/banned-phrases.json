  "patterns": [
    {
      "name": "ticket archaeology (WATS-nn)",
      "regex": "\\bWATS-\\d+\\b"
    },
    {
      "name": "phase label (F-n / B1 / B2 / C2 / D1)",
      "regex": "\\b(?:F-\\d{1,2}|B[12]|C[12]|D1)\\b(?=[^a-z]|$)"
    },
    {
      "name": "phase label (T-nn)",
      "regex": "\\bT\\d{1,2}\\b(?=[^a-z]|$)"
    },
    {
      "name": "architecture ticket (Arch-X)",
      "regex": "\\bArch-[A-Z]\\b"
    },
    {
      "name": "reviewer-gate jargon",
      "regex": "adversarial (?:remediation|closure|battery)"
    }
  ]
}
