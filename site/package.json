{
  "name": "@wats/site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "gen:meta": "bun scripts/gen-meta.ts",
    "check": "bun run typecheck && bun run typecheck:snippets && bun run gen:hero && bun run build && bun scripts/check-canaries.ts && bun scripts/check-pages.ts && bun scripts/check-banned-phrases.ts",
    "typecheck:snippets": "cd snippets && bun install --frozen-lockfile && bun run typecheck",
    "gen:hero": "bun scripts/gen-hero-capture.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.11",
    "fumadocs-ui": "16.9.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/mdx": "2.0.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "7.3.5"
  }
}